# 应用配置
APP_ENV=development
APP_SECRET_KEY=your-secret-key-here-change-in-production
APP_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# 数据库
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/ai_eval_db

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=your-jwt-secret-key-here
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# 加密密钥（用于加密资产配置中的 API Key 等敏感信息）
ENCRYPTION_KEY=your-32-byte-encryption-key-here

# 文件存储（MinIO）
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=ai-eval-reports

# 邮件通知（可选）
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
